# ─────────────────────────────────────────────
# COMPLY GLOBALLY BOT — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# Your Interakt API Key (from Interakt Dashboard → Settings → API)
INTERAKT_API_KEY=your_interakt_api_key_here

# Your Anthropic API Key (from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Port (Render sets this automatically, leave as 5000 for local)
PORT=5000
